{
  "manifest_version": 3,
  "name": "Token Rank for X",
  "version": "0.1.0",
  "description": "Show Codex token usage rank badges on X profiles.",
  "permissions": [
    "storage",
    "tabs",
    "scripting"
  ],
  "action": {
    "default_title": "Token Rank",
    "default_popup": "popup.html"
  },
  "optional_host_permissions": [
    "https://*.workers.dev/*",
    "https://api.tokenrank.xyz/*",
    "https://chatgpt.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*"
      ],
      "js": [
        "config.js",
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://chatgpt.com/codex/*"
      ],
      "js": [
        "codex-scraper.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
